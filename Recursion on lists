# Largest Array Element
# Algorithm

def MaxElementArray(a):
    length=len(a)
    if length==1:
        return a[0]
    return max(a[0],MaxElementArray(a[1:]))
a=[1,2,34,5,66,7,8,654,3,322,344,565]

print("Largest element of the array",MaxElementArray(a))
