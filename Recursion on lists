    print("\nYes given array is sorted")
else:
    print("\nNo given array is not sorted")

#Recursive Array Sum
def arrayTotalSum(a):
    length=len(a)
    if length ==1:
        return a[0]
    return a[0] + arrayTotalSum(a[1:])
a=[1,9,3,6]

print("The sum is",arrayTotalSum(a))
