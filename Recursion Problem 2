# Balance Parenthesis
# Algorithm 
# Input: n=number of pair brackets
# Output: All valid balanced bracket combinations

# Steps: 
# 1. Start with empty string
# 2. if the number of left brackets { used is less than n, add {
# 3. if the number of right brackets } used is less than left brackets used, add }
# 4. Repeat recursively
# 5. When the string length becomes 2*n, print the result

# paren(s,l,r,p,n)
# s - store the current bracket sequence
# l - number of { used
# r - number of } used
# p - current position of array
# n - total number of brackets

def paren(s,l,r,p,n):
    if(p==2*n):
        for ss in s:
            print(ss,end='')
        print("\n")
        return
    if(l>r):
        s[p]="}"
        paren(s,l,r+1,p+1,n)
    if(l<n):
        s[p]="{"
        paren(s,l+1,r,p+1,n)

n=int(input("Enter the number of parenthesis: "))
s=[""]*2*n
print("\n")
paren(s,0,0,0,n)
